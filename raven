#!/usr/bin/env bash
# raven — CLI for building and developing Raven applications
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUST_DIR="$SCRIPT_DIR/rust/raven-core"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${CYAN}raven${NC} — Raven Framework CLI"
    echo ""
}

print_usage() {
    print_header
    echo "Usage: raven <command> [options]"
    echo ""
    echo "Commands:"
    echo "  build       Build the Raven project (Rust + Swift)"
    echo "  dev         Build, run, and watch for changes (hot reload)"
    echo "  run         Build and run the application"
    echo "  clean       Clean all build artifacts"
    echo "  version     Print version information"
    echo ""
    echo "Options:"
    echo "  --release   Build in release mode (default: debug)"
    echo "  --target    Specify the executable target (default: RavenDemo)"
    echo ""
}

# Build the Rust core library
build_rust() {
    local mode="${1:-debug}"
    echo -e "${YELLOW}[1/2]${NC} Building raven-core (Rust)..."

    local cargo_args=""
    if [ "$mode" = "release" ]; then
        cargo_args="--release"
    fi

    (cd "$RUST_DIR" && cargo build $cargo_args 2>&1) || {
        echo -e "${RED}Error:${NC} Rust build failed."
        exit 1
    }
    echo -e "${GREEN}  ✓${NC} raven-core built ($mode)"
}

# Build the Swift package
build_swift() {
    local mode="${1:-debug}"
    echo -e "${YELLOW}[2/2]${NC} Building Raven (Swift)..."

    local swift_args=""
    if [ "$mode" = "release" ]; then
        swift_args="-c release"
    fi

    (cd "$SCRIPT_DIR" && swift build $swift_args 2>&1) || {
        echo -e "${RED}Error:${NC} Swift build failed."
        exit 1
    }
    echo -e "${GREEN}  ✓${NC} Raven built ($mode)"
}

# Find the built executable
find_executable() {
    local mode="${1:-debug}"
    local target="${2:-RavenDemo}"

    # Swift PM puts executables in .build/<mode>/
    local exe_path="$SCRIPT_DIR/.build/$mode/$target.exe"
    if [ ! -f "$exe_path" ]; then
        # Try without .exe (Unix)
        exe_path="$SCRIPT_DIR/.build/$mode/$target"
    fi

    if [ -f "$exe_path" ]; then
        echo "$exe_path"
    else
        echo ""
    fi
}

# Copy SDL3.dll next to executable if needed (Windows)
ensure_sdl_dll() {
    local exe_dir="$1"
    local dll_src="$SCRIPT_DIR/vendor/SDL3/SDL3-3.4.2/lib/x64/SDL3.dll"

    if [ -f "$dll_src" ] && [ ! -f "$exe_dir/SDL3.dll" ]; then
        cp "$dll_src" "$exe_dir/"
        echo -e "${GREEN}  ✓${NC} Copied SDL3.dll"
    fi
}

# === Commands ===

cmd_build() {
    local mode="debug"
    if [[ "$*" == *"--release"* ]]; then
        mode="release"
    fi

    print_header
    echo -e "Building in ${CYAN}$mode${NC} mode..."
    echo ""

    build_rust "$mode"
    build_swift "$mode"

    echo ""
    echo -e "${GREEN}Build complete!${NC}"
}

cmd_run() {
    local mode="debug"
    local target="RavenDemo"

    for arg in "$@"; do
        case "$arg" in
            --release) mode="release" ;;
            --target=*) target="${arg#--target=}" ;;
        esac
    done

    cmd_build "$@"

    local exe
    exe=$(find_executable "$mode" "$target")
    if [ -z "$exe" ]; then
        echo -e "${RED}Error:${NC} Could not find executable '$target' in .build/$mode/"
        exit 1
    fi

    ensure_sdl_dll "$(dirname "$exe")"

    echo ""
    echo -e "${CYAN}Running${NC} $target..."
    echo "---"
    "$exe"
}

cmd_dev() {
    local mode="debug"
    local target="RavenDemo"
    local WATCH_DIRS=("Sources" "rust/raven-core/src")
    local WATCH_EXTENSIONS="swift|rs|toml"

    for arg in "$@"; do
        case "$arg" in
            --release) mode="release" ;;
            --target=*) target="${arg#--target=}" ;;
        esac
    done

    print_header
    echo -e "Starting ${CYAN}dev mode${NC} (watching for changes)..."
    echo -e "Press ${YELLOW}Ctrl+C${NC} to stop."
    echo ""

    # Initial build + run
    local app_pid=""

    rebuild_and_run() {
        # Kill previous instance
        if [ -n "$app_pid" ] && kill -0 "$app_pid" 2>/dev/null; then
            echo -e "\n${YELLOW}Stopping previous instance...${NC}"
            kill "$app_pid" 2>/dev/null || true
            wait "$app_pid" 2>/dev/null || true
        fi

        echo -e "${CYAN}Rebuilding...${NC}"
        build_rust "$mode" 2>&1 || { echo -e "${RED}Rust build failed${NC}"; return 1; }
        build_swift "$mode" 2>&1 || { echo -e "${RED}Swift build failed${NC}"; return 1; }

        local exe
        exe=$(find_executable "$mode" "$target")
        if [ -z "$exe" ]; then
            echo -e "${RED}Error:${NC} Could not find executable"
            return 1
        fi

        ensure_sdl_dll "$(dirname "$exe")"

        echo -e "${GREEN}Running${NC} $target..."
        "$exe" &
        app_pid=$!
    }

    # Cleanup on exit
    cleanup() {
        if [ -n "$app_pid" ] && kill -0 "$app_pid" 2>/dev/null; then
            kill "$app_pid" 2>/dev/null || true
        fi
        echo -e "\n${CYAN}raven dev${NC} stopped."
        exit 0
    }
    trap cleanup SIGINT SIGTERM

    rebuild_and_run

    # File watching loop — polls for changes every 2 seconds
    # (Cross-platform; doesn't require inotify/fswatch)
    local last_hash=""
    while true; do
        sleep 2

        # Hash all source files to detect changes
        local current_hash=""
        for dir in "${WATCH_DIRS[@]}"; do
            if [ -d "$SCRIPT_DIR/$dir" ]; then
                current_hash+=$(find "$SCRIPT_DIR/$dir" -type f \( -name "*.swift" -o -name "*.rs" -o -name "*.toml" \) -newer "$SCRIPT_DIR/.build" 2>/dev/null | sort | head -20)
            fi
        done

        if [ -n "$current_hash" ] && [ "$current_hash" != "$last_hash" ]; then
            last_hash="$current_hash"
            echo -e "\n${YELLOW}Changes detected — rebuilding...${NC}"
            rebuild_and_run || true
        fi
    done
}

cmd_clean() {
    print_header
    echo "Cleaning build artifacts..."

    (cd "$SCRIPT_DIR" && swift package clean 2>/dev/null) || true
    (cd "$RUST_DIR" && cargo clean 2>/dev/null) || true

    echo -e "${GREEN}Clean complete.${NC}"
}

cmd_version() {
    echo "raven 0.1.0"
    echo ""
    swift --version 2>/dev/null || echo "Swift: not found"
    echo ""
    cargo --version 2>/dev/null || echo "Cargo: not found"
}

# === Entry Point ===

case "${1:-}" in
    build)  shift; cmd_build "$@" ;;
    run)    shift; cmd_run "$@" ;;
    dev)    shift; cmd_dev "$@" ;;
    clean)  shift; cmd_clean "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h|"") print_usage ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        echo ""
        print_usage
        exit 1
        ;;
esac
